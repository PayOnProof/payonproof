{
  "name": "payonproof-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:local && node .build/local-server.js",
    "dev:ts": "node --experimental-strip-types local-server.ts",
    "dev:vercel": "vercel dev --yes --listen 3001 --local-config vercel.json",
    "build:local": "tsc -p tsconfig.json --outDir .build --rootDir . --allowImportingTsExtensions false",
    "build": "echo \"Vercel builds serverless functions automatically\"",
    "typecheck": "tsc --noEmit",
    "anchors:import:file": "node scripts/import-anchor-file.mjs",
    "anchors:bootstrap": "node scripts/bootstrap-anchors.mjs",
    "anchors:export:directory": "node scripts/export-anchors-from-directory.mjs",
    "anchors:seed:import": "node scripts/import-anchor-seeds.mjs",
    "anchors:auto:sync": "node scripts/auto-sync-anchors.mjs"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.4",
    "@stellar/stellar-sdk": "^14.5.0",
    "@supabase/supabase-js": "^2.95.3"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@vercel/node": "^3.2.18",
    "typescript": "5.7.3",
    "vercel": "^48.7.3"
  }
}
